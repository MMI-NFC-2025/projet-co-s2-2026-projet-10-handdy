<footer class="bg-white border-t border-gray-200 mt-12 md:mt-16">
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-8 md:py-12">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 mb-12">
      <!-- Logo -->
      <div class="md:col-span-1">
        <img src="/icons/logo_wendy.svg" alt="Wendy Logo" class="h-8 mb-4" />
      </div>
      
      <!-- Quick Links -->
      <div>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="text-gray-700 hover:text-orange-500 transition font-medium">Accueil</a></li>
          <li><a href="#" class="text-gray-700 hover:text-orange-500 transition font-medium">Dico</a></li>
          <li><a href="/arcade" class="text-gray-700 hover:text-orange-500 transition font-medium">Arcade</a></li>
          <li><a href="/chemin" class="text-gray-700 hover:text-orange-500 transition font-medium">Progrès</a></li>
          <li><a href="#" class="text-gray-700 hover:text-orange-500 transition font-medium">Profil</a></li>
        </ul>
      </div>
      
      <!-- Spacer -->
      <div></div>
      
      <!-- Social Links -->
      <div class="flex gap-6 items-start">
        <a href="#" class="text-gray-700 hover:text-orange-500 transition" title="Facebook">
          <img src="/icons/icon_facebook.svg" alt="Facebook" class="w-6 h-6" />
