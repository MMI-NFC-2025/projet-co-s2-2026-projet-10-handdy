        <a href="#" class="text-gray-700 hover:text-orange-500 transition" title="TikTok">
          <img src="/icons/icon_tiktok.svg" alt="TikTok" class="w-6 h-6" />
        </a>
        <a href="#" class="text-gray-700 hover:text-orange-500 transition" title="YouTube">
          <img src="/icons/icon_youtube.svg" alt="YouTube" class="w-6 h-6" />
        </a>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-gray-200 pt-8 flex flex-col md:flex-row items-center justify-between text-xs md:text-sm text-gray-500">
      <p>© 2026 Wendy. Tous droits réservés.</p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-orange-500 transition">Conditions</a>
        <a href="#" class="hover:text-orange-500 transition">Confidentialité</a>
        <a href="#" class="hover:text-orange-500 transition">Contact</a>
