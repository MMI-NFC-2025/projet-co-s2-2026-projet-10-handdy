---
const { href, variant = 'primary', type = 'button', class: className = '' } = Astro.props;
const variants = {
  primary: 'bg-[#FF6200] text-white hover:bg-orange-600',
  secondary: 'bg-black text-white hover:bg-slate-900',
  ghost: 'bg-white/10 text-black hover:bg-slate-900/10 border border-black/10',
};
const classes = `inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition duration-200 shadow-lg shadow-[#ff620033] focus:outline-none focus:ring-2 focus:ring-[#FF6200]/40 ${variants[variant] ?? variants.primary} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
