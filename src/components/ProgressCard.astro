---
/**
 * ProgressCard Component
 * Affiche la carte de progression avec une image d'illustration
 */

interface Props {
  title?: string;
  image?: string;
  buttonText?: string;
}

const {
  title = 'Voir l\'avance',
  image = '/rectangle-black.svg',
  buttonText = 'Continuer'
} = Astro.props;
---

<div class="bg-green-200 rounded-3xl p-6 md:p-8 overflow-hidden">
  <div class="flex flex-col md:flex-row items-center gap-6">
    <!-- Image Section -->
    <div class="w-full md:w-2/5">
      <img
        src={image}
        alt={title}
        class="w-full h-40 md:h-56 object-cover rounded-2xl"
      />
    </div>
    
    <!-- Content Section -->
    <div class="w-full md:w-3/5 flex flex-col justify-center">
      <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
        {title}
      </h3>
      <button class="bg-green-500 hover:bg-green-600 text-white font-semibold py-3 px-6 rounded-full transition w-fit">
        {buttonText}
      </button>
    </div>
  </div>
</div>
