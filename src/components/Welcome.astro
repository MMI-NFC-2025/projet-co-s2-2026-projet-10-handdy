---
import Button from './Button.astro';
import FeatureCard from './FeatureCard.astro';
import GameCard from './GameCard.astro';
import heroPhone from '../assets/mode_arcade_landing_page.svg';
import parcoursImage from '../assets/parcour_utilisateur_landing_page.svg';
import wavesBig from '../assets/vagues_grandes.svg';
import wavesSmall from '../assets/vagues_petites.svg';
import logo from '../assets/logo_wendy.svg';
---

<main class="min-h-screen bg-white text-slate-950">
  <!-- Hero Section -->
  <section class="relative bg-[#FF6200] text-white" style="width: 100%; height: 850px; overflow: hidden;">
    <!-- Wave SVG -->
    <img src={wavesBig.src} alt="" class="absolute pointer-events-none" style="right: 0; top: 0; width: 559px; height: 850px;" />

    <!-- Header with Logo and Button -->
    <div class="relative w-full h-[155px] bg-white flex items-center justify-between px-6 md:px-10 z-20">
      <img src={logo.src} alt="Wendy Logo" class="h-[124px] w-[271px]" />
      <Button href="#play" variant="secondary" class="bg-black text-white rounded-full h-[94px] w-[429px] text-[36px] font-semibold hover:bg-slate-900 flex items-center justify-center">Commencer à jouer !</Button>
    </div>

    <!-- Content Area -->
    <div class="relative w-full z-10" style="height: 695px;">
      <div class="h-full flex items-center px-6 md:px-10">
        <div class="space-y-4 md:space-y-6 max-w-xl">
          <h1 class="text-5xl md:text-6xl leading-tight font-black text-white font-cal-sans" style="line-height: 1.2;">Apprendre la langue des<br />signes différemment !</h1>
          <p class="text-base md:text-lg leading-relaxed text-white font-alexandria font-normal" style="line-height: 1.6;">Mini-jeux, défis multijoueurs et progression fun pour<br />maîtriser la langue des signes française</p>
        </div>
      </div>

      <!-- Phone Images -->
      <img src={heroPhone.src} alt="Mode arcade" class="absolute pointer-events-none z-30" style="right: 357px; top: 213px; width: 136px; height: 281px; transform: rotate(12.75deg); border: 4px solid: 20px; 0 8px 16px rgba(0,0,0,0.3);" />
      <img src={parcoursImage.src} alt="Parcours" class="absolute pointer-events-none z-20" style="right: 201px; top: 277px; width: 154px; height: 317px; transform: rotate(-7.31deg); border: 3px solid  16px;  0 8px 16px rgba(0,0,0,0.3);" />
    </div>
  </section>

  <!-- Mode Cards Section -->
  <section class="relative px-6 py-16 md:py-24 lg:py-32 md:px-10" style="min-height: 950px;">
    <div class="relative" style="height: 750px; max-width: 1440px; margin: 0 auto;">
      <!-- Card 1 - Position X=170, Y=1079 relative to container -->
      <div class="absolute" style="left: 170px; top: 0;">
        <FeatureCard 
          icon="📖"
          title="Mode Entraînement" 
          description="Un parcours pédagogique par paliers thématiques"
          features={["Mini-jeux éducatifs (Memory, Cards, Quiz)", "Système de vies et streak", "Mode hors ligne disponible"]}
        />
      </div>

      <!-- Card 2 - Position X=850, Y=1079 relative to container -->
      <div class="absolute" style="left: 850px; top: 0;">
        <FeatureCard 
          icon="🎮"
          title="Mode Arcade" 
          description="Action et compétition ! Joue en solo ou en multijoueur."
          features={["Mini-jeux dynamiques et compétitifs", "Mode Battle multijoueur en temps réel", "Classements et scores", "Éliminations progressives"]}
        />
      </div>
    </div>
  </section>

  <!-- Mini Games Section -->
  <section id="play" class="relative px-6 py-16 md:py-24 lg:py-32 md:px-10">
    <div class="flex justify-center mb-12">
      <!-- Button 5 minis-jeux variés: X=364, Y=1839, W=712, H=94 -->
      <div class="flex items-center justify-center gap-6" style="width: 712px; height: 94px; background-color: #000000; border-radius: 50px;">
        <div class="text-white font-cal-sans" style="font-size: 48px; line-height: 1;">5 minis-jeux variés</div>
      </div>
    </div>

    <!-- Mini Games Grid -->
    <div class="mx-auto max-w-8xl">
      <div class="grid gap-4 md:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-5">
        <GameCard title="Cards" description="Apprends par flashcards visuelles." />
        <GameCard title="Memory" description="Teste ta mémoire des signes." />
        <GameCard title="Mode Héros" description="Des aventures guidées et défis quotidiens." />
        <GameCard title="Traduction" description="Convertis des mots en gestes facilement." />
        <GameCard title="Vitesse" description="Défie le chrono et améliore ta réactivité." />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="relative overflow-hidden bg-white py-16 md:py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 md:px-10">
      <h2 class="text-center text-[64px] font-normal text-slate-950 mb-12 md:mb-16 font-cal-sans">Fonctionnalités uniques</h2>
    </div>

    <div class="relative w-full">
      <div class="relative bg-[#FF6200] text-white overflow-hidden" style="width: 100%; height: 546px;">
        <!-- Vague petite en bas à gauche -->
        <img src={wavesSmall.src} alt="" class="pointer-events-none absolute" style="left: -150px; bottom: -50px; width: 650px; height: 650px; transform: scaleX(-1) scaleY(-1);" />

        <!-- Vague petite en haut à droite -->
        <img src={wavesSmall.src} alt="" class="pointer-events-none absolute" style="right: -150px; top: -50px; width: 650px; height: 650px;" />

        <!-- Conteneur pour les ronds -->
        <div class="absolute inset-0 flex items-center justify-center gap-20 px-6 md:px-10">
          <!-- Rond 1: Miroir Interactif -->
          <div class="flex flex-col items-center justify-center rounded-full bg-white text-black" style="width: 314px; height: 314px; flex-shrink: 0;">
            <div class="mb-4 text-4xl">📷</div>
            <h3 class="text-[20px] font-bold mb-3 text-center px-6 font-cal-sans">Miroir Interactif</h3>
            <p class="text-[16px] leading-relaxed text-center px-6 font-alexandria">Comprendre les gestes avec la modalité en temps réel via la caméra</p>
          </div>

          <!-- Rond 2: Mode Hors Ligne -->
          <div class="flex flex-col items-center justify-center rounded-full bg-white text-black" style="width: 314px; height: 314px; flex-shrink: 0;">
            <div class="mb-4 text-4xl">📡</div>
            <h3 class="text-[20px] font-bold mb-3 text-center px-6 font-cal-sans">Mode Hors Ligne</h3>
            <p class="text-[16px] leading-relaxed text-center px-6 font-alexandria">Télécharge les packs de lignes pour progresser partout facilement</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="mx-auto max-w-7xl px-6 py-12 md:py-16 lg:py-20 md:px-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">
      <div class="flex-1">
        <img src={logo.src} alt="Wendy Logo" class="h-12 md:h-14 w-auto mb-4" />
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-950 font-cal-sans">Prêt à maîtriser la LSF ?</h2>
      </div>
      <div class="flex-1 w-full">
        <div class="bg-slate-950 rounded-[28px] px-6 md:px-8 py-6 md:py-8">
          <p class="text-white text-sm md:text-base mb-4 font-medium">Rejoins la communauté Wendy et commence ton aventure des aujourd'hui!</p>
          <form class="flex flex-col sm:flex-row gap-3">
            <input type="email" placeholder="Ton email" class="flex-1 rounded-full border-none bg-white/95 px-5 py-3 text-slate-950 placeholder:text-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF6200]" />
            <Button type="submit" class="bg-[#FF6200] text-white hover:bg-orange-600 rounded-full px-6 py-3 font-semibold text-sm md:text-base">Commencer gratuitement</Button>
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

      <header class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src={logo.src} alt="Handdy Logo" class="h-12 w-auto" />
          <div class="space-y-1">
          </div>
        </div>
        <Button href="#play" variant="secondary" class="hidden md:inline-flex">Commencer à jouer !</Button>
      </header>

      <section class="mt-12 grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div class="space-y-8">
          <div class="space-y-6">
            <h1 class="max-w-2xl text-4xl font-black leading-tight tracking-tight sm:text-5xl">Apprendre la langue des signes facilement !</h1>
            <p class="max-w-xl text-base leading-8 text-white/90 sm:text-lg">Mini-jeux multijoueurs, défis progressifs et parcours ludiques pour maîtriser la langue des signes française.</p>
          </div>
          <div class="flex flex-wrap gap-4">
            <Button href="#features" variant="secondary">Découvrir l’app</Button>
          </div>
        </div>

        <div class="relative mx-auto max-w-[520px]">
          <div class="absolute -left-10 top-10 hidden h-36 w-36 rounded-full bg-white/15 blur-3xl md:block" />
          <div class="relative overflow-hidden rounded-[36px] border border-white/20 bg-white/10 p-4 shadow-[0_40px_80px_rgba(0,0,0,0.16)] backdrop-blur-xl">
            <img src={heroPhone.src} alt="Aperçu de l’application Handdy" class="w-full rounded-[32px] object-cover" />
          </div>
          <div class="pointer-events-none absolute -bottom-10 right-4 hidden h-40 w-40 opacity-90 md:block">
            <img src={parcoursImage.src} alt="Illustration parcours utilisateur" class="h-full w-full object-contain" />
          </div>
        </div>
      </section>
    </div>
  </section>

  <section id="play" class="mx-auto max-w-7xl px-6 py-14 md:px-10 lg:py-20">
    <div class="grid gap-6 lg:grid-cols-2">
      <FeatureCard title="Mode Entraînement" description="Un parcours pédagogique par paliers thématiques pour apprendre à ton rythme." />
      <FeatureCard title="Mode Arcade" description="Action et compétition : joue seul ou à plusieurs avec des défis chronométrés." />
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 rounded-full bg-slate-950 px-6 py-5 text-white shadow-[0_30px_80px_rgba(0,0,0,0.18)] md:flex-row">
      <p class="text-sm font-semibold uppercase tracking-[0.35em]">5 mini-jeux variés</p>
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-3xl bg-white/10"></div>
        <div class="h-10 w-10 rounded-3xl bg-white/10"></div>
      </div>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-5">
      <GameCard title="Cards" description="Apprends par flashcards visuelles." />
      <GameCard title="Memory" description="Teste ta mémoire des signes." />
      <GameCard title="Mode Héros" description="Des aventures guidées et défis quotidiens." />
      <GameCard title="Traduction" description="Convertis des mots en gestes facilement." />
      <GameCard title="Vitesse" description="Défie le chrono et améliore ta réactivité." />
    </div>
  </section>

  <section id="features" class="relative overflow-hidden bg-slate-50 px-6 py-16 md:px-10 lg:py-24">
    <div class="absolute right-0 top-0 hidden h-72 w-72 rounded-full bg-[#FF6200]/10 blur-3xl md:block"></div>
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-[#FF6200]">Fonctionnalités uniques</p>
        <h2 class="max-w-xl text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Des outils pensés pour progresser en LSF</h2>
        <p class="max-w-xl text-base leading-8 text-slate-600">Une expérience immersive, même hors ligne, avec des modes conçus pour t’aider à mémoriser et pratiquer au quotidien.</p>
      </div>

      <div class="space-y-6">
        <div class="rounded-[36px] bg-[#FF6200] p-8 text-white shadow-[0_40px_120px_rgba(255,98,0,0.18)]">
          <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-black text-white">
            <span class="text-base font-black">i</span>
          </div>
          <h3 class="text-2xl font-bold">Mode immersif</h3>
          <p class="mt-4 text-sm leading-7 text-white/90">Entraînement avec retours visuels et progression étape par étape pour ancrer chaque signe.</p>
        </div>

        <div class="rounded-[36px] bg-white p-8 shadow-[0_30px_80px_rgba(0,0,0,0.08)]">
          <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-[#FF6200] text-white">
            <span class="text-base font-black">☁</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-950">Mode Hors Ligne</h3>
          <p class="mt-4 text-sm leading-7 text-slate-600">Télécharge ton parcours pour réviser sans connexion et garder ta progression.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 px-6 py-16 text-white md:px-10 lg:py-20">
    <div class="mx-auto max-w-7xl rounded-[36px] bg-slate-900/90 p-8 shadow-[0_40px_120px_rgba(0,0,0,0.26)] sm:p-12">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-4">
          <div class="inline-flex h-12 items-center gap-3 rounded-3xl bg-white/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.35em] text-white/90">Handdy</div>
          <div>
            <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Prêt à maîtriser la LSF ?</h2>
            <p class="mt-2 max-w-2xl text-base leading-8 text-white/70">Reçois des conseils gratuits et sois notifié du lancement de la version complète.</p>
          </div>
        </div>

        <form class="flex flex-col gap-4 sm:flex-row">
          <input type="email" placeholder="Ton email" class="min-w-0 rounded-full border border-white/10 bg-white/10 px-5 py-3 text-sm text-white placeholder:text-white/50 outline-none focus:border-white/40 focus:ring-2 focus:ring-white/20" />
          <Button type="submit">Essayer la version gratuite</Button>
        </form>
      </div>
    </div>
  </section>
</main>
