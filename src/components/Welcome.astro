---
import Button from './Button.astro';
import FeatureCard from './FeatureCard.astro';
import GameCard from './GameCard.astro';
import heroPhone from '../assets/mode_arcade_landing_page.svg';
import parcoursImage from '../assets/parcour_utilisateur_landing_page.svg';
import wavesBig from '../assets/vagues_grandes.svg';
import wavesSmall from '../assets/vagues_petites.svg';
import logo from '../assets/logo_wendy.svg';
---

<main class="min-h-screen bg-white text-slate-950">
  <section class="relative overflow-hidden bg-[#FF6200] text-white">
    <img src={wavesBig.src} alt="" class="pointer-events-none absolute right-0 top-0 hidden h-[30rem] w-auto md:block" />
    <div class="mx-auto max-w-7xl px-6 py-8 md:px-10 lg:py-12">
      <header class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src={logo.src} alt="Handdy Logo" class="h-12 w-auto" />
          <div class="space-y-1">
          </div>
        </div>
        <Button href="#play" variant="secondary" class="hidden md:inline-flex">Commencer à jouer !</Button>
      </header>

      <section class="mt-12 grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div class="space-y-8">
          <div class="space-y-6">
            <h1 class="max-w-2xl text-4xl font-black leading-tight tracking-tight sm:text-5xl">Apprendre la langue des signes facilement !</h1>
            <p class="max-w-xl text-base leading-8 text-white/90 sm:text-lg">Mini-jeux multijoueurs, défis progressifs et parcours ludiques pour maîtriser la langue des signes française.</p>
          </div>
          <div class="flex flex-wrap gap-4">
            <Button href="#features" variant="secondary">Découvrir l’app</Button>
          </div>
        </div>

        <div class="relative mx-auto max-w-[520px]">
          <div class="absolute -left-10 top-10 hidden h-36 w-36 rounded-full bg-white/15 blur-3xl md:block" />
          <div class="relative overflow-hidden rounded-[36px] border border-white/20 bg-white/10 p-4 shadow-[0_40px_80px_rgba(0,0,0,0.16)] backdrop-blur-xl">
            <img src={heroPhone.src} alt="Aperçu de l’application Handdy" class="w-full rounded-[32px] object-cover" />
          </div>
          <div class="pointer-events-none absolute -bottom-10 right-4 hidden h-40 w-40 opacity-90 md:block">
            <img src={parcoursImage.src} alt="Illustration parcours utilisateur" class="h-full w-full object-contain" />
          </div>
        </div>
      </section>
    </div>
  </section>

  <section id="play" class="mx-auto max-w-7xl px-6 py-14 md:px-10 lg:py-20">
    <div class="grid gap-6 lg:grid-cols-2">
      <FeatureCard title="Mode Entraînement" description="Un parcours pédagogique par paliers thématiques pour apprendre à ton rythme." />
      <FeatureCard title="Mode Arcade" description="Action et compétition : joue seul ou à plusieurs avec des défis chronométrés." />
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 rounded-full bg-slate-950 px-6 py-5 text-white shadow-[0_30px_80px_rgba(0,0,0,0.18)] md:flex-row">
      <p class="text-sm font-semibold uppercase tracking-[0.35em]">5 mini-jeux variés</p>
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-3xl bg-white/10"></div>
        <div class="h-10 w-10 rounded-3xl bg-white/10"></div>
      </div>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-5">
      <GameCard title="Cards" description="Apprends par flashcards visuelles." />
      <GameCard title="Memory" description="Teste ta mémoire des signes." />
      <GameCard title="Mode Héros" description="Des aventures guidées et défis quotidiens." />
      <GameCard title="Traduction" description="Convertis des mots en gestes facilement." />
      <GameCard title="Vitesse" description="Défie le chrono et améliore ta réactivité." />
    </div>
  </section>

  <section id="features" class="relative overflow-hidden bg-slate-50 px-6 py-16 md:px-10 lg:py-24">
    <div class="absolute right-0 top-0 hidden h-72 w-72 rounded-full bg-[#FF6200]/10 blur-3xl md:block"></div>
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-[#FF6200]">Fonctionnalités uniques</p>
        <h2 class="max-w-xl text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Des outils pensés pour progresser en LSF</h2>
        <p class="max-w-xl text-base leading-8 text-slate-600">Une expérience immersive, même hors ligne, avec des modes conçus pour t’aider à mémoriser et pratiquer au quotidien.</p>
      </div>

      <div class="space-y-6">
        <div class="rounded-[36px] bg-[#FF6200] p-8 text-white shadow-[0_40px_120px_rgba(255,98,0,0.18)]">
          <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-black text-white">
            <span class="text-base font-black">i</span>
          </div>
          <h3 class="text-2xl font-bold">Mode immersif</h3>
          <p class="mt-4 text-sm leading-7 text-white/90">Entraînement avec retours visuels et progression étape par étape pour ancrer chaque signe.</p>
        </div>

        <div class="rounded-[36px] bg-white p-8 shadow-[0_30px_80px_rgba(0,0,0,0.08)]">
          <div class="mb-5 inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-[#FF6200] text-white">
            <span class="text-base font-black">☁</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-950">Mode Hors Ligne</h3>
          <p class="mt-4 text-sm leading-7 text-slate-600">Télécharge ton parcours pour réviser sans connexion et garder ta progression.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 px-6 py-16 text-white md:px-10 lg:py-20">
    <div class="mx-auto max-w-7xl rounded-[36px] bg-slate-900/90 p-8 shadow-[0_40px_120px_rgba(0,0,0,0.26)] sm:p-12">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-4">
          <div class="inline-flex h-12 items-center gap-3 rounded-3xl bg-white/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.35em] text-white/90">Handdy</div>
          <div>
            <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Prêt à maîtriser la LSF ?</h2>
            <p class="mt-2 max-w-2xl text-base leading-8 text-white/70">Reçois des conseils gratuits et sois notifié du lancement de la version complète.</p>
          </div>
        </div>

        <form class="flex flex-col gap-4 sm:flex-row">
          <input type="email" placeholder="Ton email" class="min-w-0 rounded-full border border-white/10 bg-white/10 px-5 py-3 text-sm text-white placeholder:text-white/50 outline-none focus:border-white/40 focus:ring-2 focus:ring-white/20" />
          <Button type="submit">Essayer la version gratuite</Button>
        </form>
      </div>
    </div>
  </section>
</main>
