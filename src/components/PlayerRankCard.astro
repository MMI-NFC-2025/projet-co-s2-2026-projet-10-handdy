---
/**
 * PlayerRankCard Component - Carte de classement d'un joueur
 */

interface Props {
  rank: number;
  name: string;
  avatar?: string;
  xp: number;
}

const { rank, name, avatar, xp } = Astro.props;

const getRankColor = (rank: number) => {
  if (rank === 1) return 'bg-yellow-400';
  if (rank === 2) return 'bg-slate-300';
  if (rank === 3) return 'bg-orange-300';
  return 'bg-slate-200';
};
---

<div class="flex items-center gap-4 p-4 bg-white rounded-2xl hover:shadow-md transition">
  <div class={`flex items-center justify-center w-10 h-10 rounded-full font-bold text-sm md:text-base ${getRankColor(rank)} text-slate-900 flex-shrink-0`}>
    {rank}
  </div>

  <div class="flex-shrink-0">
    {avatar ? (
      <img src={avatar} alt={name} class="w-12 h-12 md:w-14 md:h-14 rounded-full object-cover" />
    ) : (
      <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-slate-300 flex items-center justify-center">
        <span class="text-xl">👤</span>
      </div>
    )}
  </div>

  <div class="flex-1 min-w-0">
    <p class="font-semibold text-slate-900 truncate">{name}</p>
  </div>

  <div class="flex items-center gap-2 flex-shrink-0">
    <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <span class="font-bold text-slate-900">{xp.toLocaleString()}</span>
  </div>
</div>
