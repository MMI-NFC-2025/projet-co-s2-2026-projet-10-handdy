---
/**
 * ArcadeGameCard Component - Carte de jeu pour la page arcade
 */

interface Props {
  title: string;
  description: string;
  icon?: string;
  soloLink?: string;
  multiLink?: string;
}

const { title, description, icon, soloLink = '#', multiLink = '#' } = Astro.props;
---

<div class="bg-white rounded-3xl p-6 md:p-8 shadow-md hover:shadow-lg transition-shadow">
  <div class="flex items-start gap-4 mb-4">
    {icon && (
      <img src={icon} alt={title} class="w-16 h-16 md:w-20 md:h-20 object-cover rounded-xl flex-shrink-0" />
    )}
    <div class="flex-1">
      <h3 class="text-xl md:text-2xl font-bold text-slate-900 font-cal-sans">{title}</h3>
      <p class="text-sm md:text-base text-slate-600 mt-1">{description}</p>
    </div>
  </div>

  <!-- Game Mode Buttons -->
  <div class="flex gap-3 mt-6 flex-wrap">
    <a 
      href={soloLink}
      class="flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 px-4 md:px-6 rounded-full transition duration-200"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
      </svg>
      Jouer solo
    </a>
    
    <a 
      href={multiLink}
      class="flex items-center gap-2 bg-orange-300 hover:bg-orange-400 text-slate-800 font-semibold py-2 px-4 md:px-6 rounded-full transition duration-200"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
      </svg>
      Multi
    </a>
  </div>
</div>
