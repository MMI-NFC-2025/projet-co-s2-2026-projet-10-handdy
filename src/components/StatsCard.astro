---
/**
 * StatsCard Component
 * Affiche une statistique avec un badge et un nombre
 */

interface Props {
  count: number;
  label: string;
  icon?: string;
  variant?: 'series' | 'xp';
}

const {
  count,
  label,
  icon = '/icons/badge_serie_accueil.svg',
  variant = 'series'
} = Astro.props;
---

<div class="bg-orange-400 rounded-2xl p-4 md:p-6 text-center shadow-md hover:shadow-lg transition">
  {icon && (
    <div class="flex justify-center mb-3">
      <img src={icon} alt={label} class="w-12 h-12 md:w-16 md:h-16 object-contain" />
    </div>
  )}
  <p class="text-4xl md:text-5xl font-bold text-white mb-2">{count}</p>
  <p class="text-sm md:text-base text-white/90">{label}</p>
</div>
