---
import Menu from './menu.astro';
---

<header class="bg-orange-500 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 md:px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/icons/logo_wendy.svg" alt="Wendy Logo" class="h-8 md:h-10" />
      </a>
      
      <!-- Navigation Links - Desktop -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class="text-white hover:text-orange-100 font-medium transition">
          Accueil
        </a>
        <a href="#" class="text-white hover:text-orange-100 font-medium transition">
          Dic
        </a>
        <a href="/arcade" class="text-white hover:text-orange-100 font-medium transition">
          Arcade
        </a>
        <a href="/chemin" class="text-white hover:text-orange-100 font-medium transition">
          Progrès
        </a>
        <a href="#" class="text-white hover:text-orange-100 font-medium transition">
          Profil
        </a>
      </div>

      <!-- Mobile Menu Icon -->
      <Menu />
    </div>
  </nav>
</header>
