---
/**
 * BadgeGrid Component
 * Affiche les badges déverrouillés et verrouillés
 */

interface Badge {
  id: string;
  name: string;
  icon?: string;
  unlocked: boolean;
}

interface Props {
  badges: Badge[];
}

const {
  badges
} = Astro.props;
---

<div class="space-y-4">
  <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Badges</h2>
  
  <div class="grid grid-cols-3 gap-3 md:gap-6">
    {badges.map((badge) => (
      <div class="flex flex-col items-center">
        <div 
          class={`w-20 h-20 md:w-24 md:h-24 rounded-2xl flex items-center justify-center mb-2 transition-opacity ${
            badge.unlocked 
              ? 'bg-yellow-400 hover:bg-yellow-500' 
              : 'bg-slate-300 opacity-60'
          }`}
        >
          {badge.icon ? (
            <img 
              src={badge.icon} 
              alt={badge.name}
              class="w-12 h-12 md:w-16 md:h-16 object-contain"
            />
          ) : (
            <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-400 rounded" />
          )}
        </div>
        <p class="text-xs md:text-sm font-semibold text-center text-slate-900 line-clamp-2">
          {badge.name}
        </p>
      </div>
    ))}
  </div>
</div>
