---
/**
 * WeeklyStats Component
 * Affiche les statistiques de la semaine avec les XP par jour
 */

interface DayStats {
  day: string;
  shortDay: string;
  xp: number;
}

interface Props {
  weekStats: DayStats[];
  totalXPWeek: number;
  mascotteIcon?: string;
  wendyLogo?: string;
}

const {
  weekStats,
  totalXPWeek,
  mascotteIcon,
  wendyLogo
} = Astro.props;
---

<div class="space-y-4">
  <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Cette semaine</h2>
  
  <div class="bg-white rounded-2xl p-6 md:p-8 shadow-md">
    <!-- Chart -->
    <div class="mb-8">
      <div class="flex items-end justify-between gap-3 md:gap-4 h-16 md:h-20 mb-4">
        {weekStats.map((day) => {
          const maxXP = Math.max(...weekStats.map(d => d.xp));
          const heightPercentage = maxXP > 0 ? (day.xp / maxXP) * 100 : 0;
          const isActive = day.xp > 0;
          const barHeight = isActive ? Math.max(heightPercentage, 20) : 12;
          
          return (
            <div class="flex-1 flex flex-col items-center justify-end gap-0">
              <!-- Bar -->
              <div
                class={`w-full rounded-t-lg transition-all duration-300 ${
                  isActive ? 'bg-orange-500 hover:bg-orange-600' : 'bg-slate-300'
                }`}
                style={`height: ${barHeight}px`}
                title={`${day.day}: ${day.xp} XP`}
              />
            </div>
          );
        })}
      </div>

      <!-- Day Labels and XP -->
      <div class="flex items-center justify-between gap-3 md:gap-4">
        {weekStats.map((day) => {
          const isActive = day.xp > 0;
          
          return (
            <div class="flex-1 flex flex-col items-center gap-1">
              <!-- Day Label -->
              <span class="text-xs md:text-sm font-semibold text-slate-900">
                {day.shortDay}
              </span>
              <!-- XP Count -->
              <span class={`text-xs md:text-sm font-bold ${
                isActive ? 'text-orange-500' : 'text-slate-400'
              }`}>
                {day.xp}
              </span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- XP Total -->
    <div class="flex items-center justify-between pt-6 border-t border-slate-200">
      <span class="text-slate-600 font-medium text-sm md:text-base">XP cette semaine</span>
      <div class="flex items-center gap-3">
        <span class="text-3xl md:text-4xl font-bold text-orange-500">
          {totalXPWeek}
        </span>
        {mascotteIcon && (
          <img 
            src={mascotteIcon} 
            alt="Mascotte" 
            class="w-8 h-8 md:w-10 md:h-10 flex-shrink-0"
          />
        )}
      </div>
    </div>
  </div>
</div>
