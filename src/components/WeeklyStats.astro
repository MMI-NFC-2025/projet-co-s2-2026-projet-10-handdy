---
/**
 * WeeklyStats Component
 * Affiche les statistiques de la semaine avec les XP par jour
 */

interface DayStats {
  day: string;
  shortDay: string;
  xp: number;
}

interface Props {
  weekStats: DayStats[];
  totalXPWeek: number;
}

const {
  weekStats,
  totalXPWeek
} = Astro.props;
---

<div class="space-y-4">
  <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Cette semaine</h2>
  
  <div class="bg-white rounded-2xl p-6 md:p-8 shadow-md">
    <!-- Chart -->
    <div class="flex items-end justify-between gap-2 md:gap-4 h-40 md:h-48 mb-6">
      {weekStats.map((day) => {
        const maxXP = Math.max(...weekStats.map(d => d.xp));
        const heightPercentage = maxXP > 0 ? (day.xp / maxXP) * 100 : 0;
        
        return (
          <div class="flex-1 flex flex-col items-center justify-end gap-2">
            <div
              class="w-full bg-orange-500 rounded-t-lg transition-all duration-300"
              style={`height: ${heightPercentage}%`}
              title={`${day.day}: ${day.xp} XP`}
            />
            <span class="text-xs md:text-sm font-semibold text-slate-600">
              {day.shortDay}
            </span>
            <span class="text-xs text-slate-500">
              {day.xp}
            </span>
          </div>
        );
      })}
    </div>

    <!-- XP Total -->
    <div class="flex items-center justify-between pt-6 border-t border-slate-200">
      <span class="text-slate-600 font-medium">XP cette semaine</span>
      <div class="flex items-center gap-2">
        <span class="text-3xl md:text-4xl font-bold text-orange-500">
          {totalXPWeek}
        </span>
        <img 
          src="/icons/logo_wendy.svg" 
          alt="Wendy" 
          class="w-6 h-6 md:w-8 md:h-8"
        />
      </div>
    </div>
  </div>
</div>
