---
const { icon, title, description, class: className = '' } = Astro.props;
---

<div class={`group rounded-[30px] border border-white/80 bg-white/95 p-6 shadow-[0_24px_80px_rgba(255,98,0,0.14)] ${className}`}>
  <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-3xl bg-[#FF6200] text-white">
    {icon ? <img src={icon} alt="" class="h-7 w-7 object-contain" /> : <span class="block h-3.5 w-3.5 rounded-sm bg-white" />}
  </div>
  <h3 class="text-lg font-semibold text-slate-950">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>
</div>
