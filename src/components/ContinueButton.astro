---
/**
 * ContinueButton Component
 * Bouton avec action pour continuer vers la prochaine section
 */

interface Props {
  text?: string;
  href?: string;
  image?: string;
}

const {
  text = "Voir l'avancé",
  href = "#",
  image = '/images/chemin_utilisateur_accueil.webp'
} = Astro.props;
---

<div class="space-y-4">
  <a href={href} class="block">
    <div 
      class="bg-gradient-to-r from-green-400 to-green-500 rounded-3xl p-6 md:p-8 shadow-md overflow-hidden relative h-64 md:h-80 flex items-center justify-center"
      style={`background-image: url(${image}); background-size: cover; background-position: center;`}
    >
      <!-- Overlay for better text contrast -->
      <div class="absolute inset-0 bg-black/20 rounded-3xl"></div>
      
      <!-- Content centered on image -->
      <div class="relative z-10 text-center">
        <div class="inline-block bg-transparent border-2 border-white rounded-full px-8 md:px-12 py-4 md:py-6">
          <h3 class="text-3xl md:text-4xl font-bold text-white">
            {text}
          </h3>
        </div>
      </div>
    </div>
  </a>
</div>
