---
/**
 * GameModeCard Component
 * Affiche une carte pour un mode de jeu avec icône et description
 */

interface Props {
  title: string;
  description: string;
  icon?: string;
  badge?: string;
  onClick?: string;
}

const {
  title,
  description,
  icon,
  badge,
  onClick
} = Astro.props;
---

<div class="bg-white rounded-3xl p-6 md:p-8 shadow-lg hover:shadow-xl transition text-center cursor-pointer">
  <!-- Icon -->
  {icon ? (
    <div class="flex justify-center mb-4">
      <img src={icon} alt={title} class="w-16 h-16 md:w-20 md:h-20 object-contain" />
    </div>
  ) : (
    <div class="flex justify-center mb-4">
      <div class="w-16 h-16 md:w-20 md:h-20 bg-black rounded-lg"></div>
    </div>
  )}
  
  <!-- Title -->
  <h3 class="text-xl md:text-2xl font-bold text-slate-900 mb-2">
    {title}
  </h3>
  
  <!-- Description -->
  <p class="text-slate-600 text-sm md:text-base mb-4">
    {description}
  </p>
  
  <!-- Badge if exists -->
  {badge && (
    <span class="inline-block bg-orange-100 text-orange-600 px-4 py-2 rounded-full text-sm font-semibold mb-4">
      {badge}
    </span>
  )}
</div>
