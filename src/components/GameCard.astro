---
const { title, description, icon, class: className = '' } = Astro.props;
---

<div class={`flex flex-col items-center justify-center gap-3 rounded-[24px] bg-[#FF6200] px-6 md:px-8 py-8 md:py-10 text-center text-white shadow-lg h-[280px] md:h-[320px] ${className}`}>
  <div class="flex h-10 md:h-12 w-10 md:w-12 items-center justify-center rounded-full bg-white/20">
    <span class="text-2xl md:text-3xl">🎮</span>
  </div>
  <h4 class="text-[24px] font-bold">{title}</h4>
  <p class="text-[16px] text-white/90 leading-snug">{description}</p>
</div>
