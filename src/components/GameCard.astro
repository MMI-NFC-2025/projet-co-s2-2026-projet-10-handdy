---
const { title, description, icon, class: className = '' } = Astro.props;
---

<div class={`flex flex-col items-center justify-center gap-3 rounded-[24px] bg-[#FF6200] px-4 md:px-5 py-5 md:py-6 text-center text-white shadow-lg ${className}`}>
  <div class="flex h-10 md:h-12 w-10 md:w-12 items-center justify-center rounded-full bg-white/20">
    <span class="text-lg md:text-xl">🎮</span>
  </div>
  <h4 class="text-base md:text-lg font-bold">{title}</h4>
  <p class="text-xs md:text-sm text-white/90 leading-snug">{description}</p>
</div>
